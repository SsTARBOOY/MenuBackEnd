# server/.env.test.example  —  copia a .env.test (gitignored) y rellena.
# SOLO entorno de PRUEBA. NUNCA credenciales/host/BD de producción.
# El guardrail (tests/e2e/global-setup.ts) ABORTA la corrida si detecta prod.

ALLOW_E2E=true            # confirmación explícita de que es entorno de prueba (obligatorio)
NODE_ENV=test
PORT=4000

# Facturama: MOCK local (default) o SANDBOX. PROHIBIDO api.facturama.mx (prod).
FACTURAMA_URL=http://127.0.0.1:4555     # mock determinista (CERO folios). Sandbox real: https://apisandbox.facturama.mx
FACTURAMA_USER=test
FACTURAMA_PASS=test
FACTURAMA_CP=76000

# Base de datos de PRUEBA (NO los nombres/host de prod). E2E_DB=true habilita la suite con BD.
E2E_DB=false              # ponlo en true cuando tengas la BD de prueba seedeada (ver seed.sql)
DB_GUERRERO_HOST=127.0.0.1
DB_GUERRERO_USER=test
DB_GUERRERO_PASSWORD=test
DB_GUERRERO_NAME=lapena_test_guerrero
DB_GUERRERO_PORT=3306
DB_MADERO_HOST=127.0.0.1
DB_MADERO_USER=test
DB_MADERO_PASSWORD=test
DB_MADERO_NAME=lapena_test_madero
DB_MADERO_PORT=3306

# Ventana de facturación abierta en pruebas (evita falsos negativos por borde de mes).
FACT_VENTANA_MODO=dias
FACT_VENTANA_DIAS=3650

# JWT de prueba (camino admin). Cualquier secreto.
TOKEN_SECRET=test-secret-e2e

# Rate-limits/lockout holgados en pruebas (todos los tests pegan desde la misma IP 127.0.0.1).
SOLICITAR_RATE_MAX=100000
REOBT_RATE_MAX=100000
FACT_IP_MAX_FAILS=100000
FACT_FOLIO_MAX_FAILS=100000

# Sentry/Telegram DEBEN quedar fuera de .env.test (el guardrail aborta si aparecen).
