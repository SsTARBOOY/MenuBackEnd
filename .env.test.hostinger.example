# ─────────────────────────────────────────────────────────────────────────────
# .env.test.hostinger.example — PLANTILLA para correr la e2e (project "grace")
# contra la BD de prueba Hostinger `testOrdenar`, SIN MySQL local.
#
# ⚠️  Copia esto a  server/.env.test  y rellena los <PLACEHOLDERS>.
#     `.env.test` está GITIGNORED y NUNCA se commitea (lleva credenciales).
#     Esta plantilla NO contiene secretos — host y credenciales van como placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# ── Opt-in de prueba (no-secreto; literal) ──
ALLOW_E2E=true
ALLOW_HOSTINGER_TESTDB=true        # habilita el host de Hostinger SOLO para TEST_DB_ALLOWLIST (nombre exacto)
E2E_DB=true                        # corre los casos grace CON BD

# ── Facturama: MOCK local (lo levanta el harness; los casos grace no llaman a Facturama) ──
FACTURAMA_URL=http://127.0.0.1:4555
FACTURAMA_USER=mock
FACTURAMA_PASS=mock

TOKEN_SECRET=cualquier-cosa-para-pruebas
PORT=4000

# ── BD de prueba testOrdenar ──
# USA UN USUARIO HOSTINGER DE MÍNIMO PRIVILEGIO con GRANT SOLO sobre testOrdenar (NO el principal).
# HOST y credenciales = PLACEHOLDERS: rellénalos en tu .env.test, no aquí (no exponer en repos públicos).
DB_GUERRERO_HOST=<HOST_HOSTINGER>            # tu host MySQL de Hostinger
DB_GUERRERO_PORT=3306
DB_GUERRERO_NAME=u522428285_testOrdenar      # debe coincidir con TEST_DB_ALLOWLIST (tests/e2e/global-setup.ts)
DB_GUERRERO_USER=<USUARIO_SOLO_testOrdenar>
DB_GUERRERO_PASSWORD=<PASSWORD>
# Madero apunta a la MISMA testOrdenar (los tests grace solo usan guerrero; esto solo satisface el guardrail):
DB_MADERO_HOST=<HOST_HOSTINGER>
DB_MADERO_PORT=3306
DB_MADERO_NAME=u522428285_testOrdenar
DB_MADERO_USER=<USUARIO_SOLO_testOrdenar>
DB_MADERO_PASSWORD=<PASSWORD>

# ── NO incluir (el guardrail aborta si aparecen) ──
# SENTRY_DSN=...            ← dejar fuera
# NOTIFY_TELEGRAM_TOKEN=... ← dejar fuera
